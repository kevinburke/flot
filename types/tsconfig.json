{
	"compilerOptions": {
		"target": "ES2019",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2019", "DOM"],
		"strict": true,
		"noEmit": true,
		"skipLibCheck": true,
		"types": ["jquery"],
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true
	},
	"include": ["*.d.ts", "test.ts"]
}
